{
  "name": "edog",
  "version": "1.0.0",
  "description": "像素边牧桌面电子宠物",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "ELECTRON_RUN_AS_NODE= electron .",
    "generate-tray-icon": "node scripts/generate-tray-icon.js",
    "generate-app-icon": "node scripts/generate-app-icon.js",
    "build": "npm run generate-app-icon && electron-builder",
    "build:mac": "npm run generate-app-icon && electron-builder --mac",
    "dist": "npm run build",
    "dist:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.edog.bordercollie",
    "productName": "像素边牧",
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "category": "public.app-category.entertainment",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "index.html",
      "styles.css",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontc/edog.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/frontc/edog/issues"
  },
  "homepage": "https://github.com/frontc/edog#readme",
  "dependencies": {
    "electron-log": "^5.4.3"
  }
}
